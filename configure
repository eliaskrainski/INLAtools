#!/bin/sh

echo "Running configure..."

: ${R_HOME=$(R RHOME)}

OPENMP_CPPFLAGS=""
OPENMP_CFLAGS=""
OPENMP_LIBS=""

# Ask R first
OMP_FLAG=$(${R_HOME}/bin/R CMD config SHLIB_OPENMP_CFLAGS)

if test -n "$OMP_FLAG"; then
  echo "R provides OpenMP"
  OPENMP_CFLAGS="$OMP_FLAG"
  OPENMP_LIBS="$OMP_FLAG"
else
  echo "R has no OpenMP, checking macOS..."

  if [ "$(uname -s)" = "Darwin" ]; then

    ARCH=$(uname -m)

    if [ "$ARCH" = "arm64" ]; then
      BREW=/opt/homebrew
    else
      BREW=/usr/local
    fi

    if [ -d "$BREW/opt/libomp" ]; then
      echo "Using Homebrew libomp"

      OPENMP_CPPFLAGS="-I$BREW/opt/libomp/include"
      OPENMP_CFLAGS="-fopenmp"
      OPENMP_LIBS="-L$BREW/opt/libomp/lib -lomp"
    else
      echo "WARNING: libomp not found"
    fi
  fi
fi

# Linux gets -ldl
DL_LIBS=""
if [ "$(uname -s)" = "Linux" ]; then
  DL_LIBS="-ldl"
fi

echo "Generating src/Makevars..."

sed \
  -e "s|@OPENMP_CPPFLAGS@|$OPENMP_CPPFLAGS|g" \
  -e "s|@OPENMP_CFLAGS@|$OPENMP_CFLAGS|g" \
  -e "s|@OPENMP_LIBS@|$OPENMP_LIBS $DL_LIBS|g" \
  src/Makevars.in > src/Makevars

exit 0
