
PKG_CFLAGS = $(SHLIB_OPENMP_CFLAGS)

PKG_CPPFLAGS = -I/opt/homebrew/opt/libomp/include -I/usr/local/opt/libomp/include

PKG_LIBS = $(SHLIB_OPENMP_CFLAGS) \
           -L/opt/homebrew/opt/libomp/lib -L/usr/local/opt/libomp/lib -lomp \
           -Wl,-rpath,/opt/homebrew/opt/libomp/lib -Wl,-rpath,/usr/local/opt/libomp/lib \
           $(LAPACK_LIBS) \
           $(BLAS_LIBS) \
           $(FLIBS) \
           $(SHLIB_LDFLAGS) \
           -lm -ldl
