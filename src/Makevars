PKG_CFLAGS += $(SHLIB_OPENMP_CFLAGS)

PKG_LIBS += $(SHLIB_OPENMP_CFLAGS) \
            $(LAPACK_LIBS) \
            $(BLAS_LIBS) \
            $(FLIBS) \
            $(SHLIB_LDFLAGS) \
            -lm

# macOS: help find libomp (safe if unused)
PKG_CPPFLAGS += -I/opt/homebrew/opt/libomp/include -I/usr/local/opt/libomp/include
PKG_LIBS += -L/opt/homebrew/opt/libomp/lib -L/usr/local/opt/libomp/lib -lomp
